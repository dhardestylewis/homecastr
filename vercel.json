{
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run build",
  "crons": [
    {
      "path": "/api/cron/keepalive",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/warm-tiles",
      "schedule": "0 */3 * * *"
    }
  ]
}
